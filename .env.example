# Copia este archivo a .env y completa los valores. El .env NO se versiona.
#   cp .env.example .env
#
# Credenciales de Telegram (OBLIGATORIAS).
#   - Token: creá un bot con @BotFather y copiá el token que te da.
#   - Chat ID: el ID del chat/usuario/canal que recibe las alertas.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Opcionales (se muestran los valores por defecto) ---
# LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
# CHECK_INTERVAL=60           # segundos entre rondas de comprobación
# HTTP_TIMEOUT=10             # timeout HTTP por defecto (segundos)
# HTTP_REINTENTOS=2           # reintentos ante errores de red (por comprobación)
# HTTP_BACKOFF=1.0            # backoff base en segundos (crece de forma exponencial)
# UMBRAL_FALLOS=2             # fallos consecutivos para marcar un servicio INACTIVO
# UMBRAL_EXITOS=1             # éxitos consecutivos para marcar un servicio ACTIVO
# SERVICES_MONITOR_CONFIG=services.json   # ruta al JSON de servicios
# SERVICES_JSON=[...]         # alternativa: definir los servicios en línea (JSON)
